{
  "name": "ai-content-strategist-interviewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' next dev",
    "dev:stable": "NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' next dev --webpack",
    "build": "next build",
    "migrate": "node migrations/run.mjs",
    "start": "next start",
    "start:prodlike": "next build && next start",
